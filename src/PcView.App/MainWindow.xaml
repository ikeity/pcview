<Window x:Class="PcView.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PcView"
        Width="1320"
        Height="820"
        MinWidth="1120"
        MinHeight="680"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Color x:Key="AppBackground">#F6F7F9</Color>
        <Color x:Key="PanelBackground">#FFFFFF</Color>
        <Color x:Key="SidebarBackground">#101820</Color>
        <Color x:Key="SidebarMuted">#9CA8B5</Color>
        <Color x:Key="Ink">#17202A</Color>
        <Color x:Key="Muted">#667085</Color>
        <Color x:Key="Line">#DCE2EA</Color>
        <Color x:Key="SoftLine">#EEF1F5</Color>
        <Color x:Key="Accent">#1C6EA4</Color>
        <Color x:Key="AccentSoft">#E8F2F9</Color>
        <Color x:Key="Review">#A45D12</Color>
        <Color x:Key="ReviewSoft">#FFF4E5</Color>

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}" />
        <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelBackground}" />
        <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarBackground}" />
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="{StaticResource SidebarMuted}" />
        <SolidColorBrush x:Key="InkBrush" Color="{StaticResource Ink}" />
        <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource Muted}" />
        <SolidColorBrush x:Key="LineBrush" Color="{StaticResource Line}" />
        <SolidColorBrush x:Key="SoftLineBrush" Color="{StaticResource SoftLine}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoft}" />
        <SolidColorBrush x:Key="ReviewBrush" Color="{StaticResource Review}" />
        <SolidColorBrush x:Key="ReviewSoftBrush" Color="{StaticResource ReviewSoft}" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        </Style>

        <Style x:Key="EllipsisText" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C8D2DE" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF2F7" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E9EEF4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" CornerRadius="7" Padding="12,9" Background="Transparent">
                            <DockPanel>
                                <Border x:Name="Rail" Width="3" Height="18" CornerRadius="2" Background="Transparent" DockPanel.Dock="Left" Margin="0,0,10,0" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1B2630" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#21313D" />
                                <Setter TargetName="Rail" Property="Background" Value="#62B5E5" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource SoftLineBrush}" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="RowHeight" Value="42" />
            <Setter Property="ColumnHeaderHeight" Value="38" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FAFBFC" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="{StaticResource SoftLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="12,0" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FBFE" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="ReasonTemplate">
            <Border Background="{StaticResource ReviewSoftBrush}" CornerRadius="6" Padding="8,4" Margin="0,0,6,6">
                <TextBlock Text="{Binding}" Foreground="{StaticResource ReviewBrush}" FontSize="12" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SourceBadgeTemplate">
            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left">
                <TextBlock Text="{Binding SourceLabel}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ReasonBadgeTemplate">
            <StackPanel Orientation="Horizontal">
                <Border Background="{StaticResource ReviewSoftBrush}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding PrimaryReason}" Foreground="{StaticResource ReviewBrush}" FontSize="12" FontWeight="SemiBold" />
                </Border>
                <TextBlock Text="{Binding ExtraReasonCount}" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="244" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="382" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Background="{StaticResource SidebarBrush}">
            <DockPanel Margin="18">
                <StackPanel DockPanel.Dock="Top">
                    <Border Width="42" Height="42" CornerRadius="10" Background="#62B5E5" HorizontalAlignment="Left" Margin="0,0,0,12">
                        <TextBlock Text="P" FontSize="22" FontWeight="Bold" Foreground="#101820" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="PcView" FontSize="25" FontWeight="SemiBold" Foreground="#FFFFFF" />
                    <TextBlock x:Name="AppSubtitleText" Text="Local software inventory" Foreground="{StaticResource SidebarMutedBrush}" Margin="0,4,0,22" />

                    <Button x:Name="ScanButton" AutomationProperties.AutomationId="ScanButton" Content="Scan now" Style="{StaticResource PrimaryButton}" Click="ScanButton_Click" />
                    <Button x:Name="RefreshButton" AutomationProperties.AutomationId="RefreshButton" Content="Rebuild index" Margin="0,8,0,20" Click="RefreshButton_Click" />

                    <TextBlock x:Name="ViewsLabelText" Text="VIEWS" Foreground="{StaticResource SidebarMutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,6,0,8" />
                    <RadioButton x:Name="OverviewFilter" AutomationProperties.AutomationId="OverviewFilter" Content="Overview" IsChecked="True" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Filter_Checked" />
                    <RadioButton x:Name="ReviewFilter" AutomationProperties.AutomationId="ReviewFilter" Content="Review queue" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Filter_Checked" />
                    <RadioButton x:Name="AllFilter" AutomationProperties.AutomationId="AllFilter" Content="All apps" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Filter_Checked" />
                    <RadioButton x:Name="FolderFilter" AutomationProperties.AutomationId="FolderFilter" Content="Folder discoveries" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Filter_Checked" />
                    <RadioButton x:Name="UnknownFilter" AutomationProperties.AutomationId="UnknownFilter" Content="Unknown evidence" GroupName="Nav" Style="{StaticResource NavButton}" Checked="Filter_Checked" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom" Background="#17222B" CornerRadius="8" Padding="12">
                    <StackPanel>
                        <TextBlock x:Name="SafetyTitleText" Text="Safe by design" Foreground="#FFFFFF" FontWeight="SemiBold" />
                        <TextBlock x:Name="SafetyBodyText" Text="PcView does not delete files, clean registry keys, or run silent uninstallers."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource SidebarMutedBrush}"
                                   Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="0" Grid.Column="1" Margin="24,22,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="PageTitleText" Text="Software inventory" FontSize="26" FontWeight="SemiBold" />
                    <TextBlock x:Name="SubtitleText" Text="Scan registered apps, shortcuts, common app folders, and local evidence." Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                </StackPanel>
                <Grid DockPanel.Dock="Right" Width="340">
                    <TextBox x:Name="SearchBox"
                             AutomationProperties.AutomationId="SearchBox"
                             Padding="34,0,12,0"
                             ToolTip="Search by name, publisher, path, executable, or reason"
                             TextChanged="SearchBox_TextChanged" />
                    <TextBlock x:Name="SearchLabelText" Text="Search" Foreground="{StaticResource MutedBrush}" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" />
                    <TextBlock x:Name="SearchHint" Text="name, publisher, path, exe" Foreground="{StaticResource MutedBrush}" Margin="70,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" />
                </Grid>
            </DockPanel>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,18,0,16">
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="AppsMetricLabelText" Text="Apps" Style="{StaticResource MutedText}" />
                        <TextBlock x:Name="AppCountText" Text="-" FontSize="27" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="ReviewMetricLabelText" Text="Review" Style="{StaticResource MutedText}" />
                        <TextBlock x:Name="ReviewCountText" Text="-" FontSize="27" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="FoldersMetricLabelText" Text="Folders" Style="{StaticResource MutedText}" />
                        <TextBlock x:Name="FolderCountText" Text="-" FontSize="27" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock x:Name="DurationMetricLabelText" Text="Duration" Style="{StaticResource MutedText}" />
                        <TextBlock x:Name="DurationText" Text="-" FontSize="27" FontWeight="SemiBold" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid x:Name="OverviewPanel" Grid.Row="2" AutomationProperties.AutomationId="OverviewPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,12">
                    <StackPanel>
                        <TextBlock x:Name="ReviewFocusTitleText" Text="Review focus" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="ReviewFocusText" Text="Run a scan to build the review queue." Style="{StaticResource MutedText}" Margin="0,6,0,14" TextWrapping="Wrap" />
                        <ItemsControl x:Name="TopReasonsList" ItemTemplate="{StaticResource ReasonTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="10,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="EvidenceHealthTitleText" Text="Evidence health" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="EvidenceHealthText" Text="Evidence confidence will appear after scanning." Style="{StaticResource MutedText}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="WorkflowTitleText" Text="Suggested workflow" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="WorkflowStep1Text" Text="1. Scan or rebuild the local index." Style="{StaticResource MutedText}" Margin="0,12,0,0" />
                        <TextBlock x:Name="WorkflowStep2Text" Text="2. Review folder discoveries and unknown publishers first." Style="{StaticResource MutedText}" Margin="0,7,0,0" />
                        <TextBlock x:Name="WorkflowStep3Text" Text="3. Open folders or locate executables before running uninstall entries." Style="{StaticResource MutedText}" Margin="0,7,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock x:Name="SafeBoundaryTitleText" Text="Safe action boundary" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="SafeBoundaryBodyText" Text="PcView does not remove files, clean registry keys, or run silent uninstallers. Uncertainty is shown as evidence quality, not as alarm language."
                                   Style="{StaticResource MutedText}"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="AppsTableCard" Grid.Row="2" Style="{StaticResource Card}" Padding="0" Visibility="Collapsed">
                <DataGrid x:Name="AppsGrid"
                          AutomationProperties.AutomationId="AppsGrid"
                          AutoGenerateColumns="False"
                          SelectionChanged="AppsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="NameColumn" Header="Name" Binding="{Binding Name}" Width="2.0*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EllipsisText}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn x:Name="PublisherColumn" Header="Publisher" Binding="{Binding Publisher}" Width="1.35*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource EllipsisText}" />
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn x:Name="SourceColumn" Header="Source" CellTemplate="{StaticResource SourceBadgeTemplate}" Width="128" />
                        <DataGridTextColumn x:Name="EvidenceColumn" Header="Evidence" Binding="{Binding LastRunLabel}" Width="128" />
                        <DataGridTemplateColumn x:Name="ReasonColumn" Header="Reason" CellTemplate="{StaticResource ReasonBadgeTemplate}" Width="2.2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="0" Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource SoftLineBrush}" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="22">
                    <TextBlock x:Name="InspectorTitleText" Text="Inspector" FontSize="21" FontWeight="SemiBold" />
                    <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="14" Margin="0,16,0,18">
                        <StackPanel>
                            <TextBlock x:Name="DetailNameText" Text="Select an app" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock x:Name="DetailMetaText" Text="Run a scan, then choose an item to inspect evidence and actions." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="EvidenceSectionTitleText" Text="Evidence" Style="{StaticResource SectionTitleText}" />
                    <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,16">
                        <TextBlock x:Name="EvidenceText" Text="-" TextWrapping="Wrap" />
                    </Border>

                    <TextBlock x:Name="LocationSectionTitleText" Text="Location" Style="{StaticResource SectionTitleText}" />
                    <Border Style="{StaticResource Card}" Padding="12" Margin="0,0,0,16">
                        <TextBlock x:Name="LocationText" Text="-" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                    </Border>

                    <TextBlock x:Name="ReasonsSectionTitleText" Text="Review reasons" Style="{StaticResource SectionTitleText}" />
                    <ItemsControl x:Name="ReasonsList" ItemTemplate="{StaticResource ReasonTemplate}" Margin="0,0,0,16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <TextBlock x:Name="ExecutablesSectionTitleText" Text="Executables" Style="{StaticResource SectionTitleText}" />
                    <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,18">
                        <ListBox x:Name="ExecutablesList"
                                 AutomationProperties.AutomationId="ExecutablesList"
                                 MaxHeight="188"
                                 BorderThickness="0"
                                 Background="Transparent" />
                    </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="1" Background="#FAFBFC" BorderBrush="{StaticResource SoftLineBrush}" BorderThickness="0,1,0,0" Padding="22,14">
                    <StackPanel>
                        <TextBlock x:Name="ActionsSectionTitleText" Text="Actions" Style="{StaticResource SectionTitleText}" />
                        <Button x:Name="OpenFolderButton" AutomationProperties.AutomationId="OpenFolderButton" Content="Open folder" Click="OpenFolderButton_Click" IsEnabled="False" Margin="0,0,0,8" />
                        <Button x:Name="SelectExeButton" AutomationProperties.AutomationId="SelectExeButton" Content="Locate executable" Click="SelectExeButton_Click" IsEnabled="False" Margin="0,0,0,8" />
                        <Button x:Name="UninstallButton" AutomationProperties.AutomationId="UninstallButton" Content="Run official uninstall entry" Click="UninstallButton_Click" IsEnabled="False" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource SoftLineBrush}" BorderThickness="0,1,0,0">
            <DockPanel Margin="14,0">
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Text="Ready." Style="{StaticResource MutedText}" />
                <TextBlock x:Name="CacheText" DockPanel.Dock="Right" VerticalAlignment="Center" Style="{StaticResource MutedText}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
